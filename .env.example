# ============================================
# Gold Fib Signals Environment Configuration
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Database (SQLite - automatically created in backend/data/)
# No configuration needed for SQLite

# ============================================
# Email Configuration (SMTP)
# ============================================

# SMTP Settings for sending notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=your-email@gmail.com
FROM_NAME="Gold Fib Signals"

# Admin email for receiving approval requests
ADMIN_EMAIL=admin@example.com

# ============================================
# Encryption (REQUIRED for secure email storage)
# ============================================

# Generate a key using: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# This key is used to encrypt email addresses with AES-256-GCM
# KEEP THIS SECRET - losing it means losing access to subscriber emails
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here

# ============================================
# Stripe Configuration (Optional)
# ============================================

# Stripe API keys for donation processing
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# Data Provider API Keys
# ============================================

# FreeGoldAPI (for historical data)
FREEGOLD_API_KEY=your-freegold-api-key

# ============================================
# Polling Configuration
# ============================================

# Swissquote polling interval in milliseconds (default: 60000 = 1 minute)
POLL_INTERVAL_MS=60000

# ============================================
# Application URL
# ============================================

# Base URL for generating links in emails
APP_URL=https://trade-gold.scottkennedy.dev